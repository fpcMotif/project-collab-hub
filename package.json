{
  "name": "project-collab-hub",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:fix": "turbo run format:fix",
    "check-types": "turbo run check-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "validate": "bun run lint && bun run check-types && bun run test && bun run build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "convex": "^1.33.1",
    "ultracite": "7.4.0"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.58.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.3"
}
